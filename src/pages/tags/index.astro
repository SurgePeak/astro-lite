---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { slugifyStr } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Redirect to 404 page if `showTags` config is false
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (!config.features.showTags && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const t = useTranslations(locale);

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);

const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    const slug = slugifyStr(tag);
    counts.set(slug, (counts.get(slug) ?? 0) + 1);
  }
}

const tagsWithCount = tags
  .map(t => ({ ...t, count: counts.get(t.tag) ?? 0 }))
  .sort((a, b) => b.count - a.count || a.tagName.localeCompare(b.tagName));
---

<Layout title={`${t.pages.tagsTitle} | ${config.site.title}`}>
  <Header pageTitle={t.pages.tagsTitle} />

  <Main>
    <ul class="flex flex-wrap gap-2">
      {
        tagsWithCount.map(({ tag, tagName }) => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
              transition:name={tag}
              class="bg-foreground/10 hover:bg-foreground/20 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-sm transition-colors"
            >
              <span class="opacity-60">#</span>
              <span>{tagName}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
